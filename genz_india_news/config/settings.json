{
  "candidate_pool_size": 200,
  "max_candidates_per_publication": 40,
  "max_headlines_per_sector": 100,
  "locale": {
    "hl": "en",
    "gl": "IN",
    "ceid": "IN:en"
  },
  "request": {
    "timeout_seconds": 10,
    "max_retries": 3,
    "backoff_base_seconds": 2,
    "delay_between_requests_seconds": 1
  },
  "news_lookback_hours": 24,
  "thin_pool_fallback": {
    "sectors": ["Science & Space", "World News", "AI"],
    "min_candidates": 30
  },
  "groq_model": "llama-3.1-8b-instant",
  "groq_request_delay_seconds": 0.3,
  "groq_max_retries": 3,
  "use_llm_relevance_filter": true,
  "use_llm_genz_scoring": true,
  "llm_genz_scoring_top_n": 100,
  "output_dir": "output",
  "log_file": "logs/pipeline.log",
  "schedule_time": "07:00"
}
