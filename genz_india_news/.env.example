# Groq API key for the optional LLM relevance filter + GenZ scoring signal
# (llm_relevance_filter.py, genz_scorer.py). Get a free key at:
#   https://console.groq.com/keys
#
# Only needed if use_llm_relevance_filter or use_llm_genz_scoring is set to
# true in config/settings.json -- the pipeline runs fine on rule-based
# scoring alone without this set.
#
# Copy this file to .env (which is gitignored) and fill in your real key
# for local development. On Streamlit Community Cloud, set this in the
# app's Settings -> Secrets instead -- see README.md.
GROQ_API_KEY=your_groq_api_key_here
